# Mẫu biến môi trường — COPY sang .env (local) hoặc khai báo trên Vercel (production).
# KHÔNG commit .env thật (đã nằm trong .gitignore).

# PostgreSQL — production nên dùng Neon (https://neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Chuỗi bí mật ký JWT — đặt chuỗi ngẫu nhiên dài, khác nhau giữa các môi trường
JWT_SECRET="doi-thanh-chuoi-ngau-nhien-dai"
